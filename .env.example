# .env.local
# Copy this file to .env.local and fill in values

# Refresh interval in milliseconds (default: 15000 = 15 seconds)
NEXT_PUBLIC_REFRESH_INTERVAL=15000

# Optional: Set to "simulation" to always use simulated prices (no Yahoo scraping)
# Set to "live" to attempt Yahoo Finance scraping
PRICE_SOURCE=simulation

# Optional: Rapid API key if you use a paid Yahoo Finance API
# RAPIDAPI_KEY=your_key_here
